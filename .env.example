# Copy this file to .env and fill in at least ONE LLM key.
# The app auto-detects the best available provider in priority order.

# ── Option 1: Anthropic (paid) ────────────────────────────────────────────────
# console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Option 2: Google Gemini (free tier) ───────────────────────────────────────
# aistudio.google.com → Get API key
GOOGLE_API_KEY=your_google_api_key_here

# ── Option 3: Groq (free tier) ────────────────────────────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Option 4: Ollama (fully local, no key needed) ─────────────────────────────
# Install: https://ollama.com  then run: ollama pull llama3.2
# No env var required — auto-detected.

# ── Storage (optional overrides) ──────────────────────────────────────────────
# USE_FIRESTORE=false        # set to true to use Firestore instead of SQLite
# SQLITE_PATH=pulse.db       # path to SQLite DB file (local dev)
# FIRESTORE_COLLECTION=pulse_health_log
